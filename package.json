{
  "name": "@tuandm/browser-cli",
  "version": "0.1.0",
  "description": "Token-efficient browser CLI for AI coding agents. Persistent headless Chromium with ARIA refs, CSS inspection, auth profiles, and 50+ commands. ~50-100 tokens per call vs ~1500 for MCP tools.",
  "keywords": [
    "playwright", "browser", "cli", "ai-agent", "claude-code",
    "headless-chrome", "testing", "automation", "token-efficient",
    "mcp-alternative", "aria-snapshot", "css-inspection"
  ],
  "author": "Tuan Duong <bacduong@gmail.com>",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuandm/browser-cli.git"
  },
  "homepage": "https://github.com/tuandm/browser-cli#readme",
  "bugs": { "url": "https://github.com/tuandm/browser-cli/issues" },
  "type": "module",
  "bin": { "browser-cli": "./bin/browse.mjs" },
  "files": ["bin/", "src/", "LICENSE", "README.md"],
  "engines": { "node": ">=18" },
  "dependencies": { "playwright": "^1.59.0" },
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "start": "node bin/browse.mjs"
  }
}
